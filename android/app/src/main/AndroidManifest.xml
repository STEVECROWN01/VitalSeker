<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internet permission required for Supabase, Google Sign-In, and API calls -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Camera permission for avatar upload, medical-records document scanning,
         and OCR text extraction in the translation feature. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Geolocation permission for the SOS screen share-location feature. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <!-- Microphone permission for AI chat voice notes (speech-to-text) and
         translation screen voice input. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Storage permissions for medical record file uploads (images/documents) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <!-- FIX (audit H-14): POST_NOTIFICATIONS is required on Android 13+
         (API 33) for local notifications to fire. Without it, the medication
         reminders, appointment reminders, triage reminders, and weekly
         insights notifications are silently blocked. The runtime permission
         request is triggered from NotificationService.initialize(). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- SCHEDULE_EXACT_ALARM: required on Android 12+ (API 31) for scheduling
         exact-time notifications (medication reminders at specific times). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- RECEIVE_BOOT_COMPLETED: so the app can reschedule notifications
         after the device reboots (otherwise all reminders are lost). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- VIBRATE: for notification vibration. -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- WAKE_LOCK: so the device wakes up to fire scheduled notifications. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- FIX (audit H-15): disable backups. The default (allowBackup="true")
         would back up the user's medical records, allergies, conditions,
         and emergency contacts to Google Drive (auto-backup) and allow
         extraction via `adb backup` on rooted devices. This is PHI
         leakage — set to false. -->
    <application
        android:label="VitalSeker"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- FIX (audit 5.9): Deep link intent filters for uni_links -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="vitalseker"/>
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="passport.vitalseker.app"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!--
        Queries for implicit intents launched by url_launcher.

        Android 11+ (API 30) enforces "package visibility" — apps can no
        longer see other installed apps by default. canLaunchUrl() returns
        false for any URI scheme that isn't declared here, which silently
        broke the SOS screen's "Find Hospitals Near Me" (geo:), phone dial
        (tel:), SMS (sms:), and the Help screen's mailto: link.

        Each <intent> below declares a scheme the app needs to be able to
        resolve. See https://developer.android.com/training/package-visibility.
    -->
    <queries>
        <!-- Browser / maps web fallbacks -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <!-- Native maps apps (geo: URI scheme) -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="geo"/>
        </intent>
        <!-- Phone dialer -->
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="tel"/>
        </intent>
        <!-- SMS composer -->
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="sms"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="sms"/>
        </intent>
        <!-- Email composer -->
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>
        <!--
            Required by the Flutter engine for the PROCESS_TEXT intent
            (text selection action). Kept from the original manifest.
        -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
